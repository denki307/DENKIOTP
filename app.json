{
  "name": "Telegram Resell Store Bot",
  "description": "A Telegram Reseller Store Bot built with Python, Pyrogram, and MongoDB.",
  "keywords": [
    "telegram",
    "bot",
    "store",
    "pyrogram",
    "python"
  ],
  "env": {
    "API_ID": {
      "description": "Your Telegram API ID from my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Your Telegram API HASH from my.telegram.org",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Your Bot Token from @BotFather",
      "required": true
    },
    "ADMIN_ID": {
      "description": "Your Telegram User ID",
      "required": true
    },
    "MONGO_URL": {
      "description": "Your MongoDB Atlas Connection String",
      "required": true
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ],
  "formation": {
    "worker": {
      "quantity": 1,
      "size": ""
    }
  }
}
