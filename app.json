{
  "name": "OTP Store Bot",
  "description": "Telegram OTP Store Bot with Automatic QR and Admin Panel",
  "repository": "https://github.com/YOUR_USERNAME/YOUR_REPO_NAME",
  "logo": "https://telegra.ph/file/your-logo-link.jpg",
  "keywords": ["telegram", "bot", "otp", "store", "python"],
  "env": {
    "BOT_TOKEN": {
      "description": "Enter your Telegram Bot Token from @BotFather",
      "required": true
    },
    "OWNER_ID": {
      "description": "Enter your Telegram User ID (e.g. 123456789)",
      "required": true
    },
    "UPI_ID": {
      "description": "Enter your UPI ID for QR generation (e.g. name@upi)",
      "required": true,
      "value": "shubhamarya55555@fam"
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": [
    "heroku-postgresql:essential-0"
  ]
}

